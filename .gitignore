# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# claude (project instructions — local only, not shared via git)
CLAUDE.md
CLAUDE.local.md
.claude/CLAUDE.local.md
.claude/settings.local.json

# Claude session files (local only — temporary per-block context)
.claude/session/

# Claude worktree directories (local only — git worktree paths)
.claude/worktrees/

# playwright generated artifacts
playwright-report/
test-results/

# audit skill screenshot artifacts (fallback — primary path is /tmp/sm-audit/)
visual-*
ux-audit-*.png
responsive/
tmp/

# supabase CLI temp files
supabase/.temp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.local.example


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Temporary files (local only)
tmp/

# One-shot scripts (local only — not for CI)
# All .mjs files at root or in scripts/ are ignored by default.
# To track a specific script, use: git add -f scripts/my-script.mjs
*.mjs
!eslint.config.mjs
!postcss.config.mjs
scripts/*.mjs
