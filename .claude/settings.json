{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeGitInstructions": false,
  "claudeMdExcludes": [
    "/Users/MarcoG/Projects/staff-manager-requirements-check/**"
  ],
  "worktree": {
    "symlinkDirectories": ["node_modules", ".next"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "LAST=$(cat ~/.claude/projects/-Users-MarcoG-Projects-staff-manager/last-audit 2>/dev/null || echo 0); NOW=$(date +%s); DIFF=$((NOW - LAST)); DAYS=$((DIFF / 86400)); if [ $DIFF -gt 604800 ]; then LAST_DATE=$([ $LAST -eq 0 ] && echo 'never' || date -r $LAST '+%Y-%m-%d' 2>/dev/null || date -d @$LAST '+%Y-%m-%d' 2>/dev/null || echo 'unknown'); echo \"⚠️  Arch audit overdue — last run: $LAST_DATE ($DAYS days ago). Run /arch-audit to check compliance with latest Anthropic docs.\"; fi",
            "async": true
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat >> /tmp/claude-instructions-$(date +%Y%m%d).log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f .claude/CLAUDE.local.md ] && echo '⚠️  Active CLAUDE.local.md overrides in effect — re-read to restore session context.' || true",
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "additionalDirectories": [
      "/Users/MarcoG/Projects/staff-manager-requirements-check"
    ],
    "allow": [
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx tsc:*)",
      "Bash(npx playwright:*)",
      "Bash(npx vitest:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git merge:*)",
      "Bash(git show:*)",
      "Bash(git restore:*)",
      "Bash(git worktree:*)",
      "Bash(git -C:*)",
      "Bash(git fetch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git:*)",
      "Bash(curl:*)",
      "Bash(/bin/ls:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(python3:*)",
      "Bash(pkill:*)",
      "Bash(unzip:*)",
      "Bash(npx shadcn:*)",
      "Bash(claude mcp:*)",
      "WebSearch",
      "WebFetch(domain:www.builder.io)",
      "WebFetch(domain:www.morphllm.com)",
      "mcp__claude_ai_Slack__slack_search_channels",
      "mcp__claude_ai_ClickUp__clickup_get_workspace_hierarchy",
      "mcp__claude_ai_n8n__search_workflows",
      "mcp__claude_ai_Supabase__execute_sql"
    ]
  }
}
